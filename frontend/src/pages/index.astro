---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  {
    title: "Maler- und Lackierarbeiten",
    text: "Saubere Oberflächen, präzise Kanten und ein stimmiges Farbkonzept."
  },
  {
    title: "Innenausbau & Sanierung",
    text: "Verlässliche Ausführung von Ausbau, Erneuerung und Instandsetzung."
  },
  {
    title: "Trockenbau & Spachtelarbeiten",
    text: "Glatte Wände, klare Linien und ein Finish, das lange hält."
  },
  {
    title: "Boden- und Oberflächen",
    text: "Robuste Grundlagen für wohnliche und professionelle Räume."
  }
];

const values = [
  {
    title: "Klare Kommunikation",
    text: "Transparente Absprachen, schnelle Rückmeldungen und feste Termine."
  },
  {
    title: "Sauberer Ablauf",
    text: "Ordnung auf der Baustelle, schonender Umgang mit Material und Umgebung."
  },
  {
    title: "Qualität im Detail",
    text: "Präzise Ausführung, sauberer Abschluss und ein professioneller Look."
  }
];

const process = [
  "Kostenlose Ersteinschätzung und Vor-Ort-Termin",
  "Individuelles Angebot mit klaren Leistungen",
  "Schnelle Umsetzung mit sauberer Abnahme"
];
---

<BaseLayout>
  <header class="section-pad flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
    <div class="flex items-center gap-4">
      <img src="/assets/logo.png" alt="Logo Robert Jan Wozniak" class="h-16 w-auto sm:h-20" />
      <div>
        <p class="text-sm uppercase tracking-[0.28em] text-moss">Dienstleistungen am Bau</p>
        <p class="text-xl font-semibold sm:text-2xl">Robert Jan Wozniak</p>
      </div>
    </div>
    <nav class="flex flex-wrap items-center gap-3 text-sm font-semibold">
      <a href="#leistungen" class="text-ink/80 transition hover:text-ink">Leistungen</a>
      <a href="#ablauf" class="text-ink/80 transition hover:text-ink">Ablauf</a>
      <a href="#kontakt" class="text-ink/80 transition hover:text-ink">Kontakt</a>
      <a href="#impressum" class="text-ink/80 transition hover:text-ink">Impressum</a>
      <a href="#kontakt" class="cta">Anfrage senden</a>
    </nav>
  </header>

  <main>
    <section class="section-pad grid gap-10 lg:grid-cols-[1.1fr,0.9fr]" data-reveal>
      <div class="flex flex-col gap-6">
        <span class="chip">Berlin & Umgebung</span>
        <h1 class="text-4xl font-display font-semibold leading-tight text-ink sm:text-5xl">
          Robert Jan Wozniak Dienstleistungen am Bau
          <span class="block text-moss">sauber, termintreu, farbtreu.</span>
        </h1>
        <p class="text-lg text-ink/70">
          Moderne Handwerksleistungen für Innenausbau, Farbe und Sanierung. Der Fokus liegt auf
          präziser Ausführung, ruhiger Kommunikation und einem Ergebnis, das professionell wirkt.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#kontakt" class="cta">Projekt anfragen</a>
          <a href="tel:+493034061990" class="cta-outline" aria-label="Direkt anrufen">Direkt anrufen</a>
          <a
            href="https://wa.me/4917684122917"
            class="cta-outline"
            target="_blank"
            rel="noreferrer"
          >
            WhatsApp
          </a>
        </div>
        <div class="mt-4 flex flex-wrap gap-3 text-sm text-ink/60">
          <span class="chip">Einzelunternehmen</span>
          <span class="chip">Saubere Baustellen</span>
          <span class="chip">Farb- und Materialberatung</span>
        </div>
      </div>
      <div class="card flex flex-col gap-6" data-reveal>
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold text-moss">Leistungsprofil</p>
        </div>
        <div class="grid gap-4">
          {services.map((service) => (
            <div class="rounded-2xl border border-clay/60 bg-white/60 p-4">
              <p class="text-base font-semibold text-ink">{service.title}</p>
              <p class="text-sm text-ink/65">{service.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="leistungen" class="section-pad" data-reveal>
      <div class="grid gap-8 lg:grid-cols-[0.9fr,1.1fr]">
        <div class="flex flex-col gap-4">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-moss">Leistungen</p>
          <h2 class="text-3xl font-display font-semibold">Sichtbare Qualität für Bau und Ausbau.</h2>
          <p class="text-ink/70">
            Ein sauberes Ergebnis entsteht durch gute Vorbereitung. Material, Farbe und Untergrund
            werden aufeinander abgestimmt, damit das Finish professionell wirkt und langlebig bleibt.
          </p>
          <a href="#kontakt" class="cta w-fit">Anfrage starten</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {values.map((value) => (
            <div class="card" data-reveal>
              <p class="text-lg font-semibold text-ink">{value.title}</p>
              <p class="text-sm text-ink/65">{value.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="ablauf" class="section-pad" data-reveal>
      <div class="card grid gap-8 lg:grid-cols-[1fr,1fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-moss">Ablauf</p>
          <h2 class="mt-3 text-3xl font-display font-semibold">Ein klarer Weg zum Ergebnis.</h2>
          <p class="mt-4 text-ink/70">
            Von der ersten Einschätzung bis zur sauberen Übergabe ist jeder Schritt strukturiert.
            Das sorgt für Planungssicherheit und ein ruhiges Projektgefühl.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          {process.map((step, index) => (
            <div class="flex items-start gap-4 rounded-2xl border border-clay/70 bg-white/70 p-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-moss text-white font-semibold">
                {index + 1}
              </div>
              <p class="text-sm text-ink/70">{step}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="kontakt" class="section-pad grid gap-8 lg:grid-cols-[1.05fr,0.95fr]" data-reveal>
      <div class="card">
        <h2 class="text-3xl font-display font-semibold">Projekt anfragen</h2>
        <p class="mt-2 text-ink/70">
          Schreibe kurz, was geplant ist. Wir melden uns zeitnah mit einer ersten Einschätzung.
        </p>
        <form
          class="mt-6 grid gap-4"
          action="mailto:wozniakbau@web.de"
          method="post"
          enctype="text/plain"
        >
          <label class="grid gap-2 text-sm font-semibold text-ink/80">
            Name
            <input
              name="name"
              required
              class="rounded-2xl border border-clay/80 bg-white/80 px-4 py-3 text-base outline-none transition focus:border-moss"
              placeholder="Dein Name"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-ink/80">
            E-Mail
            <input
              name="email"
              type="email"
              required
              class="rounded-2xl border border-clay/80 bg-white/80 px-4 py-3 text-base outline-none transition focus:border-moss"
              placeholder="dein@email.de"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-ink/80">
            Telefon (optional)
            <input
              name="phone"
              class="rounded-2xl border border-clay/80 bg-white/80 px-4 py-3 text-base outline-none transition focus:border-moss"
              placeholder="030 000000"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-ink/80">
            Nachricht
            <textarea
              name="message"
              rows="4"
              required
              class="rounded-2xl border border-clay/80 bg-white/80 px-4 py-3 text-base outline-none transition focus:border-moss"
              placeholder="Kurzbeschreibung des Projekts"
            ></textarea>
          </label>
          <button type="submit" class="cta">Anfrage per E-Mail senden</button>
        </form>
        <p class="mt-4 text-xs text-ink/60">
          Hinweis: Das Formular öffnet dein E-Mail-Programm mit der Anfrage.
        </p>
      </div>

      <div class="flex flex-col gap-6">
        <div class="card">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-moss">Direktkontakt</p>
          <div class="mt-4 grid gap-3 text-sm text-ink/70">
            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-ink/50">Telefon</p>
              <div class="flex flex-wrap items-center gap-3">
                <a class="text-lg font-semibold text-ink" href="tel:+493034061990">030 / 34061990</a>
                <button type="button" class="copy-button" data-copy="+493034061990">Kopieren</button>
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-ink/50">Mobil</p>
              <a class="text-lg font-semibold text-ink" href="tel:+4917684122917">+49 176 84122917</a>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-ink/50">E-Mail</p>
              <a class="text-lg font-semibold text-ink" href="mailto:wozniakbau@web.de">wozniakbau@web.de</a>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-ink/50">WhatsApp</p>
              <a
                class="text-lg font-semibold text-moss"
                href="https://wa.me/4917684122917"
                target="_blank"
                rel="noreferrer"
              >
                WhatsApp Business
              </a>
            </div>
          </div>
        </div>
        <div class="card">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-moss">Standort</p>
          <p class="mt-3 text-ink/70">Heilbronner Straße 29</p>
          <p class="text-ink/70">10779 Berlin</p>
        </div>
      </div>
    </section>

    <section id="impressum" class="section-pad" data-reveal>
      <div class="card">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-moss">Impressum</p>
            <h2 class="mt-3 text-2xl font-display font-semibold">Robert Jan Wozniak Dienstleistungen am Bau</h2>
            <p class="mt-2 text-ink/70">Einzelunternehmen</p>
          </div>
        </div>
        <div class="mt-6 grid gap-4 text-sm text-ink/70 sm:grid-cols-2">
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-ink/50">Adresse</p>
            <p>Heilbronner Straße 29</p>
            <p>10779 Berlin</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-ink/50">Kontakt</p>
            <p>Tel: 030 / 34061990</p>
            <p>Mobil: +49 176 84122917</p>
            <p>E-Mail: wozniakbau@web.de</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-ink/50">Steuerdaten</p>
            <p>St.-Nr.: 18/599/00256</p>
            <p>USt-IdNr.: DE355713508</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-ink/50">Unterlagen</p>
            <a class="text-moss underline" href="/assets/docs/Impressum.pdf">Impressum als PDF</a>
          </div>
        </div>
      </div>
    </section>
  </main>

</BaseLayout>
